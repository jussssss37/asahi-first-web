---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { company } from '../../data/company';
---

<Layout
  title="人材をお探しの方 | アサヒファースト"
  description="清掃業務をはじめ、製造・軽作業など幅広い業種の人材派遣に対応。即戦力となるスタッフをスピーディにご紹介します。"
>
  <Header />

  <main>

    <!-- ページヒーロー -->
    <section class="page-hero">
      <h1 class="page-hero__title">RECRUIT</h1>
      <p class="page-hero__sub">人材をお探しの方</p>
    </section>

    <!-- リード文 -->
    <section class="corp-lead fade-in">
      <div class="container">
        <div class="corp-lead__body">
          <p class="corp-lead__main">
            採用のお悩み、<span>アサヒファーストに</span>お任せください。
          </p>
          <p class="corp-lead__text">
            アサヒファーストは、清掃業務をはじめ、製造・軽作業・施設管理など幅広い業種の現場スタッフ派遣に対応する人材サービス会社です。<br />
            企業様のニーズを丁寧にお伺いし、即戦力となる人材をスピーディにご紹介します。<br />
            人手不足・急な欠員・繁忙期の増員など、どのようなご相談もお気軽にご連絡ください。
          </p>
        </div>
      </div>
    </section>

    <!-- 強み：清掃業務に強い -->
    <section class="corp-strength fade-in">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">OUR STRENGTH</h2>
          <p class="section-subtitle">アサヒファーストの強み</p>
        </div>
        <div class="corp-strength__highlight">
          <div class="corp-strength__badge">清掃業務の紹介に強い</div>
          <p class="corp-strength__highlight-text">
            清掃スタッフの採用・管理でお困りの企業様、ぜひアサヒファーストへご相談ください。<br />
            ホテル・商業施設・オフィスビル・医療施設など、様々な現場への派遣実績があります。
          </p>
        </div>
        <div class="corp-strength__cards">
          <div class="corp-strength__card">
            <div class="corp-strength__card-icon">🧹</div>
            <h3>清掃業務専門のネットワーク</h3>
            <p>清掃経験者・有資格者を中心とした豊富な人材プールを保有。即日対応が必要な現場にもスピーディに対応します。</p>
          </div>
          <div class="corp-strength__card">
            <div class="corp-strength__card-icon">📋</div>
            <h3>丁寧なスタッフ研修</h3>
            <p>派遣前に清掃手順・衛生管理・接遇マナーをしっかり指導。現場での即戦力を保証します。</p>
          </div>
          <div class="corp-strength__card">
            <div class="corp-strength__card-icon">🏢</div>
            <h3>多様な施設への対応実績</h3>
            <p>ホテル・オフィス・商業施設・医療機関・工場など、幅広い現場環境に対応できる人材をご提案します。</p>
          </div>
          <div class="corp-strength__card">
            <div class="corp-strength__card-icon">🔄</div>
            <h3>繁忙期・スポット対応</h3>
            <p>大型イベントや年末年始など、繁忙期のスポット増員にも柔軟に対応。必要な時に必要な人数をご提供します。</p>
          </div>
          <div class="corp-strength__card">
            <div class="corp-strength__card-icon">🤝</div>
            <h3>継続的なフォロー体制</h3>
            <p>派遣後も定期的にフォローを行い、トラブルやご要望にも迅速に対応。長期的なパートナーとしてご支援します。</p>
          </div>
          <div class="corp-strength__card">
            <div class="corp-strength__card-icon">⚡</div>
            <h3>スピーディなご提案</h3>
            <p>お問い合わせから最短即日でご提案。急な欠員・緊急対応にも対応できる体制を整えています。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- サービス内容 -->
    <section class="corp-service fade-in">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">SERVICE</h2>
          <p class="section-subtitle">サービス内容</p>
        </div>
        <div class="corp-service__list corp-service__list--single">
          <div class="corp-service__item">
            <div class="corp-service__item-header">
              <span class="corp-service__num">01</span>
              <h3>労働者派遣</h3>
            </div>
            <p>
              アサヒファーストが雇用するスタッフを、企業様の指揮命令のもとで就業させるサービスです。
              採用コストを抑えながら必要な人材を確保でき、繁閑に合わせた柔軟な人員調整が可能です。<br />
              清掃業務を得意としながら、製造・軽作業・施設管理など幅広い業種に対応しています。
            </p>
            <ul class="corp-service__tags">
              <li>清掃・ビルメンテナンス</li>
              <li>製造・軽作業</li>
              <li>施設管理</li>
              <li>即戦力確保</li>
              <li>採用コスト削減</li>
              <li>人員の柔軟調整</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ご利用の流れ -->
    <section class="corp-flow fade-in">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">FLOW</h2>
          <p class="section-subtitle">ご利用の流れ</p>
        </div>
        <ol class="corp-flow__steps">
          <li class="corp-flow__step">
            <div class="corp-flow__step-num">STEP 1</div>
            <div class="corp-flow__step-icon">📞</div>
            <h3>お問い合わせ</h3>
            <p>お電話またはWebフォームからお気軽にご連絡ください。ご要望・業務内容・必要人数などをお聞かせください。</p>
          </li>
          <li class="corp-flow__step">
            <div class="corp-flow__step-num">STEP 2</div>
            <div class="corp-flow__step-icon">💬</div>
            <h3>ヒアリング・ご提案</h3>
            <p>担当者が企業様の現場やご要望を丁寧にヒアリング。最適なサービスと人材をご提案します。</p>
          </li>
          <li class="corp-flow__step">
            <div class="corp-flow__step-num">STEP 3</div>
            <div class="corp-flow__step-icon">📝</div>
            <h3>契約・手続き</h3>
            <p>派遣契約を締結します。必要な書類のご案内も丁寧にサポートします。</p>
          </li>
          <li class="corp-flow__step">
            <div class="corp-flow__step-num">STEP 4</div>
            <div class="corp-flow__step-icon">👷</div>
            <h3>スタッフ就業開始</h3>
            <p>研修済みのスタッフが現場に赴きます。就業後も定期的にフォローし、安定した稼働をサポートします。</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- お問い合わせ CTA -->
    <section class="contact fade-in" id="contact">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">CONTACT</h2>
          <p class="section-subtitle">お問い合わせ</p>
        </div>
        <p class="contact__desc">
          人材に関するご相談はお気軽にお問い合わせください。<br />
          清掃業務をはじめ、あらゆる現場のご要望にお応えします。
        </p>
        <div class="contact__actions">
          <a href={`tel:${company.tel.replace(/-/g, '')}`} class="btn btn--primary btn--large">
            📞 {company.tel}
          </a>
          <a href="/contact" class="btn btn--dark btn--large">
            Webからお問い合わせ <span class="btn__arrow">→</span>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  // フェードインアニメーション
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>
